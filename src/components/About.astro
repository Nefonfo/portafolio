---
import SectionBar from './SectionBar.astro';
import { site } from '@/config/site';
---

<section id="about" class="border-b-2 border-ink">
  <div class="max-w-site mx-auto px-[clamp(1.2rem,4vw,4rem)]">
    <SectionBar num="01" title="About" />
    <div class="grid grid-cols-1 md:grid-cols-2">
      <div class="reveal py-12 pr-12 md:border-r-2 border-ink border-b-2 md:border-b-0">
        {
          site.bio.map((para) => (
            <p class="text-body text-mid leading-[1.8] mb-4" set:html={para} />
          ))
        }
      </div>
      <div class="reveal py-12 md:pl-12">
        {
          site.skills.map((group) => (
            <div class="skill-group mb-8">
              <p class="text-tag tracking-[0.12em] uppercase text-muted mb-[0.7rem] border-b border-border-dim pb-[0.4rem]">
                {group.label}
              </p>
              <div class="flex flex-wrap gap-[0.4rem]">
                {group.items.map((item) => (
                  <span class="skill-tag text-xs tracking-[0.06em] px-[0.65rem] py-[0.25rem] border border-ink text-ink hover:bg-ink hover:text-bg transition-colors duration-100 cursor-default">
                    {item}
                  </span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
