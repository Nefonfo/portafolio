---
import { site } from '@/config/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = `${site.name} — Software Developer`,
  description = 'Backend engineer specializing in Python and ERP systems.',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="bg-bg text-ink font-mono antialiased"
    style="font-size: clamp(13px, 1.1vw, 15px); line-height: 1.6;"
  >
    <slot />
    <script>
      const allReveals = document.querySelectorAll('.reveal, .reveal-left');

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            const siblings = [
              ...(el.parentElement ?? document.body).querySelectorAll('.reveal, .reveal-left'),
            ];
            const idx = siblings.indexOf(el);
            el.style.transitionDelay = Math.max(0, idx * 85) + 'ms';
            el.classList.add('visible');
            observer.unobserve(el);
          });
        },
        { threshold: 0.07 }
      );

      allReveals.forEach((el) => observer.observe(el));

      const skillObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.querySelectorAll('.skill-tag').forEach((tag, i) => {
              (tag as HTMLElement).style.transitionDelay = i * 45 + 'ms';
              tag.classList.add('visible');
            });
            skillObserver.unobserve(entry.target);
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('.skill-group').forEach((g) => skillObserver.observe(g));
    </script>
  </body>
</html>

<style is:global>
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html {
    scroll-behavior: smooth;
  }
  a {
    color: inherit;
    text-decoration: none;
  }

  .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.visible {
    opacity: 1;
    transform: none;
  }

  .reveal-left {
    opacity: 0;
    transform: translateX(-14px);
    transition:
      opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-left.visible {
    opacity: 1;
    transform: none;
  }

  .reveal-line {
    opacity: 0;
    transform: scaleX(0);
    transform-origin: left;
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal-line.visible {
    opacity: 1;
    transform: scaleX(1);
  }

  .skill-tag {
    opacity: 0;
    transform: translateY(6px);
    transition:
      background 0.1s,
      color 0.1s,
      opacity 0.4s ease,
      transform 0.4s ease;
  }
  .skill-tag.visible {
    opacity: 1;
    transform: none;
  }
</style>
